# .env example file
# Copy this to .env and fill in the actual values

# Voice TTS provider (options: edge-tts, qwen, elevenlabs, gtts)
VOICE_PROVIDER=edge-tts

# Edge TTS voice code (e.g., es-CO-SalomeNeural)
VOICE_EDGE_CODE=es-CO-SalomeNeural

# HuggingFace token for Qwen TTS (optional)
HF_API_TOKEN=your_hf_token_here

# Qwen Space URL (default: Qwen/Qwen3-TTS-Demo)
Qwen3_SPACE_URL=Qwen/Qwen3-TTS-Demo

# Qwen voice name
Qwen3_VOICE_NAME=Sonrisa / 西班牙语拉美-索尼莎

# ElevenLabs API key (optional)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Telegram bot token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Fanvue API credentials (if used)
FANVUE_API_KEY=your_fanvue_api_key_here

# Other secrets
OTHER_SECRET=placeholder
